{
  "name": "korean-law-multiagent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "db:up": "docker compose --env-file .env.local up -d postgres",
    "db:down": "docker compose --env-file .env.local down",
    "db:logs": "docker compose --env-file .env.local logs -f postgres",
    "stack:up": "docker compose --env-file .env.local up -d postgres api web db-admin",
    "stack:down": "docker compose --env-file .env.local down",
    "stack:logs": "docker compose --env-file .env.local logs -f postgres api web db-admin",
    "dev:api": "tsx apps/api/src/server.ts",
    "typecheck": "tsc --noEmit",
    "web:install": "npm --prefix apps/web install",
    "dev:web": "npm --prefix apps/web run dev",
    "web:check": "npm --prefix apps/web run check",
    "build:web": "npm --prefix apps/web run build",
    "mock:run": "tsx apps/api/src/cli/run-mock-analysis.mjs",
    "test:mock": "tsx scripts/test-pipeline.mjs",
    "test:analysis": "tsx scripts/test-analysis-architecture.ts",
    "test:analysis-sse": "tsx scripts/test-analysis-sse-contract.ts",
    "test:abuse": "tsx scripts/test-abuse-patterns.ts",
    "test:guided-extraction": "tsx scripts/test-guided-extraction-agent.ts",
    "test:bridge": "tsx scripts/test-classification-retrieval-bridge.ts",
    "test:evidence-pack": "tsx scripts/test-retrieval-evidence-pack.ts",
    "test:retrieval-snippets": "tsx scripts/test-retrieval-snippets.ts",
    "test:retrieval-rerank": "tsx scripts/test-retrieval-snippet-rerank.ts",
    "test:retrieval-provider": "tsx scripts/test-retrieval-provider-boundary.ts",
    "test:mixed-fixtures": "tsx scripts/test-mixed-case-fixtures.ts",
    "test:scope-filter": "tsx scripts/test-scope-filter-facts.mjs",
    "test:judgment-core": "tsx scripts/test-judgment-core.ts",
    "test:verification-core": "tsx scripts/test-verification-core.ts",
    "test:verification-messaging": "tsx scripts/test-verification-messaging.ts",
    "test:keyword-http": "tsx scripts/test-keyword-http-boundaries.ts",
    "test:keyword": "tsx scripts/test-keyword-service.ts",
    "test:auth": "tsx scripts/test-auth.ts",
    "test:keywords": "tsx scripts/test-keyword-verification.ts",
    "test:tools": "tsx scripts/test-tools.ts",
    "test:policy": "tsx scripts/test-password-policy.ts",
    "test": "npm run test:mock",
    "check": "npm run test:mock && npm run test:analysis && npm run test:analysis-sse && npm run test:abuse && npm run test:guided-extraction && npm run test:bridge && npm run test:evidence-pack && npm run test:retrieval-snippets && npm run test:retrieval-rerank && npm run test:retrieval-provider && npm run test:mixed-fixtures && npm run test:scope-filter && npm run test:judgment-core && npm run test:verification-core && npm run test:verification-messaging && npm run test:keyword && npm run test:keyword-http && npm run test:policy && npm run typecheck && npm run web:check"
  },
  "dependencies": {
    "cheerio": "^1.1.2",
    "dotenv": "^17.2.3",
    "nodemailer": "^8.0.5",
    "pg": "^8.16.3",
    "tesseract.js": "^6.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.15.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
